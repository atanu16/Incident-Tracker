<Window x:Class="IncidentTracker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:IncidentTracker.Views"
        xmlns:ctrl="clr-namespace:IncidentTracker.Controls"
        xmlns:svc="clr-namespace:IncidentTracker.Services"
        xmlns:conv="clr-namespace:IncidentTracker.Converters"
        Title="Incident Tracker"
        MinWidth="900" MinHeight="600"
        Width="1200" Height="780"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource WindowBgBrush}"
        FontFamily="Segoe UI">

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:InverseBoolConverter x:Key="InvBool"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="64"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ===== HEADER ===== -->
        <Border Grid.Row="0"
                Background="{DynamicResource HeaderBgBrush}"
                BorderBrush="{DynamicResource CardBorderBrush}"
                BorderThickness="0,0,0,1">
            <Border.Effect>
                <DropShadowEffect ShadowDepth="2" BlurRadius="10" Opacity="0.3" Direction="270"/>
            </Border.Effect>
            <Grid Margin="20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Logo + Title -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="36" Height="36" CornerRadius="10"
                            Background="{DynamicResource AccentBrush}" Margin="0,0,12,0">
                        <TextBlock Text="🎯" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Incident Tracker"
                                   FontSize="17" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock Text="Dashboard"
                                   FontSize="11"
                                   Foreground="{DynamicResource TextMutedBrush}"/>
                    </StackPanel>
                </StackPanel>

                <!-- Header Right Controls -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">

                    <!-- Global Refresh -->
                    <Button Command="{Binding GlobalRefreshCommand}"
                            Background="Transparent"
                            Foreground="{DynamicResource TextSecondaryBrush}"
                            BorderThickness="1" BorderBrush="{DynamicResource CardBorderBrush}"
                            Padding="12,8" Cursor="Hand" FontSize="13"
                            ToolTip="Refresh current tab">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="8" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SecondaryBtnBrush}"/>
                                        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="↺" FontSize="16" VerticalAlignment="Center"/>
                            <TextBlock Text=" Refresh" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- Theme Toggle -->
                    <Button Command="{Binding ToggleThemeCommand}"
                            Background="Transparent"
                            Foreground="{DynamicResource TextSecondaryBrush}"
                            BorderThickness="1" BorderBrush="{DynamicResource CardBorderBrush}"
                            Padding="12,8" Cursor="Hand" FontSize="13"
                            ToolTip="Toggle light/dark mode">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="8" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SecondaryBtnBrush}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <TextBlock Text="{Binding ThemeIcon}" FontSize="16" VerticalAlignment="Center"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ===== MAIN CONTENT ===== -->
        <Grid Grid.Row="1">
            <!-- Tab Control -->
            <TabControl SelectedIndex="{Binding SelectedTabIndex}"
                        Background="{DynamicResource WindowBgBrush}"
                        BorderThickness="0"
                        IsEnabled="{Binding IsLoading, Converter={StaticResource InvBool}}">
                <TabControl.Template>
                    <ControlTemplate TargetType="TabControl">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Tab Header Bar -->
                            <Border Grid.Row="0"
                                    Background="{DynamicResource CardBgBrush}"
                                    BorderBrush="{DynamicResource CardBorderBrush}"
                                    BorderThickness="0,0,0,1"
                                    Padding="16,0">
                                <TabPanel IsItemsHost="True" HorizontalAlignment="Left"/>
                            </Border>

                            <!-- Tab Content -->
                            <ContentPresenter Grid.Row="1"
                                              ContentSource="SelectedContent"/>
                        </Grid>
                    </ControlTemplate>
                </TabControl.Template>
                <TabControl.ItemContainerStyle>
                    <Style TargetType="TabItem">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="TabItem">
                                    <Border x:Name="TabBorder"
                                            Padding="20,0"
                                            Margin="0,0,4,0"
                                            Height="50"
                                            Background="Transparent"
                                            BorderThickness="0,0,0,3"
                                            BorderBrush="Transparent"
                                            Cursor="Hand">
                                        <ContentPresenter ContentSource="Header"
                                                          VerticalAlignment="Center"
                                                          HorizontalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="TabBorder" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="TabBorder" Property="Background" Value="{DynamicResource TabHoverBgBrush}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </TabControl.ItemContainerStyle>

                <!-- Dashboard Tab -->
                <TabItem>
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🏠 " FontSize="14" VerticalAlignment="Center"/>
                            <TextBlock Text="Dashboard" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </TabItem.Header>
                    <views:DashboardView DataContext="{Binding DashboardVM}"/>
                </TabItem>

                <!-- All Records Tab -->
                <TabItem>
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📋 " FontSize="14" VerticalAlignment="Center"/>
                            <TextBlock Text="All Records" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </TabItem.Header>
                    <views:AllRecordsView DataContext="{Binding AllRecordsVM}"/>
                </TabItem>

                <!-- Edit Tab -->
                <TabItem>
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="✏ " FontSize="14" VerticalAlignment="Center"/>
                            <TextBlock Text="Edit" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </TabItem.Header>
                    <views:EditView DataContext="{Binding EditVM}"/>
                </TabItem>
            </TabControl>

            <!-- ===== GLOBAL LOADING OVERLAY ===== -->
            <Grid Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
                <Rectangle Fill="{DynamicResource OverlayBgBrush}"/>
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <Viewbox Width="60" Height="60">
                        <Canvas Width="100" Height="100">
                            <Ellipse Width="90" Height="90" Canvas.Left="5" Canvas.Top="5"
                                     Stroke="#2A2A4A" StrokeThickness="8"/>
                            <Path Stroke="#6C63FF" StrokeThickness="8" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                  Data="M 50,5 A 45,45 0 0 1 95,50"
                                  RenderTransformOrigin="0.5,0.5">
                                <Path.RenderTransform>
                                    <RotateTransform CenterX="50" CenterY="50"/>
                                </Path.RenderTransform>
                                <Path.Triggers>
                                    <EventTrigger RoutedEvent="Path.Loaded">
                                        <BeginStoryboard>
                                            <Storyboard RepeatBehavior="Forever">
                                                <DoubleAnimation Storyboard.TargetProperty="(Path.RenderTransform).(RotateTransform.Angle)"
                                                                 From="0" To="360" Duration="0:0:0.8"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Path.Triggers>
                            </Path>
                        </Canvas>
                    </Viewbox>
                    <TextBlock Text="Loading data..." FontSize="15"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               HorizontalAlignment="Center" Margin="0,14,0,0"/>
                </StackPanel>
            </Grid>
        </Grid>

        <!-- ===== NOTIFICATION OVERLAY ===== -->
        <ItemsControl Grid.RowSpan="2"
                      HorizontalAlignment="Right"
                      VerticalAlignment="Top"
                      Margin="0,72,16,0"
                      Panel.ZIndex="999"
                      IsHitTestVisible="True"
                      ItemsSource="{Binding Source={x:Static svc:NotificationService.Instance},
                                            Path=Notifications}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <ctrl:NotificationControl Margin="0,0,0,8"/>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
        </ItemsControl>
    </Grid>
</Window>
