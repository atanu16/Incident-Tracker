<Window x:Class="IncidentTracker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:IncidentTracker.Views"
        xmlns:ctrl="clr-namespace:IncidentTracker.Controls"
        xmlns:svc="clr-namespace:IncidentTracker.Services"
        xmlns:conv="clr-namespace:IncidentTracker.Converters"
        Title="Incident Tracker"
        Icon="pack://application:,,,/icon.ico"
        MinWidth="900" MinHeight="600"
        Width="1200" Height="780"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        FontFamily="Segoe UI"
        ResizeMode="CanResizeWithGrip">

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:InverseBoolToVisibilityConverter x:Key="InvBoolToVis"/>
        <conv:InverseBoolConverter x:Key="InvBool"/>

        <!-- Window Button Base Style -->
        <Style x:Key="WindowBtn" TargetType="Button">
            <Setter Property="Width" Value="46"/>
            <Setter Property="Height" Value="34"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="VerticalAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SecondaryBtnBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.7"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Close Button Style (red hover) -->
        <Style x:Key="CloseBtn" TargetType="Button" BasedOn="{StaticResource WindowBtn}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="0,8,0,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#E81123"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#C50F1F"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- Outer Border = window frame with rounded corners -->
    <Border x:Name="WindowBorder" CornerRadius="8"
            Background="{DynamicResource WindowBgBrush}"
            BorderBrush="{DynamicResource CardBorderBrush}"
            BorderThickness="1"
            Margin="6">
        <Border.Effect>
            <DropShadowEffect ShadowDepth="1" BlurRadius="12" Opacity="0.35" Color="#000000"/>
        </Border.Effect>

        <!-- Clip everything to rounded corners -->
        <Border.Clip>
            <RectangleGeometry x:Name="ClipRect" RadiusX="8" RadiusY="8"/>
        </Border.Clip>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

        <!-- ===== CUSTOM TITLE BAR ===== -->
        <Border Grid.Row="0" x:Name="TitleBar" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="{DynamicResource TitleBarGradStart}" Offset="0"/>
                    <GradientStop Color="{DynamicResource TitleBarGradMid}" Offset="0.6"/>
                    <GradientStop Color="{DynamicResource TitleBarGradEnd}" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Border.Effect>
                <DropShadowEffect ShadowDepth="2" BlurRadius="10" Opacity="0.18" Direction="270"/>
            </Border.Effect>

            <Grid Height="54">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Logo + Title -->
                <StackPanel Grid.Column="0" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="16,0,0,0">
                    <!-- Animated accent icon -->
                    <Border Width="34" Height="34" CornerRadius="9"
                            Margin="0,0,12,0">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#6C63FF" Offset="0"/>
                                <GradientStop Color="#A855F7" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <Border.Effect>
                            <DropShadowEffect ShadowDepth="0" BlurRadius="10" Opacity="0.5" Color="#6C63FF"/>
                        </Border.Effect>
                        <TextBlock Text="🎯" FontSize="18"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock FontSize="15" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}">
                            <Run Text="Incident"/>
                            <Run Text=" Tracker" Foreground="#A78BFA"/>
                        </TextBlock>
                        <TextBlock Text="Dashboard" FontSize="12" Foreground="{DynamicResource TextMutedBrush}" Margin="0,-1,0,0"/>
                    </StackPanel>
                </StackPanel>

                <!-- Action buttons (compact) -->
                <StackPanel Grid.Column="2" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="0,0,4,0"
                            Visibility="{Binding IsLoading, Converter={StaticResource InvBoolToVis}}">

                    <!-- Global Refresh (compact) -->
                    <Button Command="{Binding GlobalRefreshCommand}"
                            Background="Transparent"
                            Foreground="{DynamicResource TextSecondaryBrush}"
                            BorderThickness="1" BorderBrush="{DynamicResource CompactBtnBorderBrush}"
                            Padding="6,3" Cursor="Hand" FontSize="10"
                            Margin="0,0,4,0"
                            ToolTip="Refresh current tab">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="5" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="{DynamicResource CompactBtnHoverBgBrush}"/>
                                        <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                        <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource CompactBtnHoverBorderBrush}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="↺" FontSize="12" VerticalAlignment="Center"/>
                            <TextBlock Text=" Refresh" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- Theme Toggle (compact) -->
                    <Button Command="{Binding ToggleThemeCommand}"
                            Background="Transparent"
                            Foreground="{DynamicResource TextSecondaryBrush}"
                            BorderThickness="1" BorderBrush="{DynamicResource CompactBtnBorderBrush}"
                            Padding="6,3" Cursor="Hand" FontSize="10"
                            ToolTip="Toggle light/dark mode">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="5" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="{DynamicResource CompactBtnHoverBgBrush}"/>
                                        <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource CompactBtnHoverBorderBrush}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                        <TextBlock Text="{Binding ThemeIcon}" FontSize="13" VerticalAlignment="Center"/>
                    </Button>
                </StackPanel>

                <!-- Window Controls: Min / Max / Close -->
                <StackPanel Grid.Column="3" Orientation="Horizontal"
                            VerticalAlignment="Top" Margin="8,0,0,0">
                    <Button x:Name="MinBtn" Style="{StaticResource WindowBtn}"
                            Click="MinBtn_Click" ToolTip="Minimize">
                        <Path Data="M 0,0 H 10" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              StrokeThickness="1.2" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </Button>
                    <Button x:Name="MaxBtn" Style="{StaticResource WindowBtn}"
                            Click="MaxBtn_Click" ToolTip="Maximize">
                        <Path Data="M 0,0 H 9 V 9 H 0 Z" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              StrokeThickness="1.2" Fill="Transparent" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </Button>
                    <Button x:Name="CloseButton" Style="{StaticResource CloseBtn}"
                            Click="CloseBtn_Click" ToolTip="Close">
                        <Path Data="M 0,0 L 10,10 M 10,0 L 0,10" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              StrokeThickness="1.2" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ===== MAIN CONTENT ===== -->
        <Grid Grid.Row="1">
            <!-- Tab Control -->
            <TabControl SelectedIndex="{Binding SelectedTabIndex}"
                        Background="{DynamicResource WindowBgBrush}"
                        BorderThickness="0"
                        IsEnabled="{Binding IsLoading, Converter={StaticResource InvBool}}">
                <TabControl.Template>
                    <ControlTemplate TargetType="TabControl">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Tab Header Bar -->
                            <Border Grid.Row="0"
                                    Background="{DynamicResource CardBgBrush}"
                                    BorderBrush="{DynamicResource CardBorderBrush}"
                                    BorderThickness="0,0,0,1"
                                    Padding="16,0">
                                <TabPanel IsItemsHost="True" HorizontalAlignment="Left"/>
                            </Border>

                            <!-- Tab Content -->
                            <ContentPresenter Grid.Row="1"
                                              ContentSource="SelectedContent"/>
                        </Grid>
                    </ControlTemplate>
                </TabControl.Template>
                <TabControl.ItemContainerStyle>
                    <Style TargetType="TabItem">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="TabItem">
                                    <Border x:Name="TabBorder"
                                            Padding="20,0"
                                            Margin="0,0,4,0"
                                            Height="50"
                                            Background="Transparent"
                                            BorderThickness="0,0,0,3"
                                            BorderBrush="Transparent"
                                            Cursor="Hand">
                                        <ContentPresenter ContentSource="Header"
                                                          VerticalAlignment="Center"
                                                          HorizontalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="TabBorder" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="TabBorder" Property="Background" Value="{DynamicResource TabHoverBgBrush}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </TabControl.ItemContainerStyle>

                <!-- Dashboard Tab -->
                <TabItem>
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🏠 " FontSize="14" VerticalAlignment="Center"/>
                            <TextBlock Text="Dashboard" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </TabItem.Header>
                    <views:DashboardView DataContext="{Binding DashboardVM}"/>
                </TabItem>

                <!-- All Records Tab -->
                <TabItem>
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📋 " FontSize="14" VerticalAlignment="Center"/>
                            <TextBlock Text="All Records" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </TabItem.Header>
                    <views:AllRecordsView DataContext="{Binding AllRecordsVM}"/>
                </TabItem>

                <!-- Edit Tab -->
                <TabItem>
                    <TabItem.Header>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="✏ " FontSize="14" VerticalAlignment="Center"/>
                            <TextBlock Text="Edit" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </TabItem.Header>
                    <views:EditView DataContext="{Binding EditVM}"/>
                </TabItem>
            </TabControl>

            <!-- ===== GLOBAL LOADING OVERLAY ===== -->
            <Grid Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
                <Rectangle Fill="{DynamicResource OverlayBgBrush}"/>
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <Viewbox Width="60" Height="60">
                        <Canvas Width="100" Height="100">
                            <Ellipse Width="90" Height="90" Canvas.Left="5" Canvas.Top="5"
                                     Stroke="#2A2A4A" StrokeThickness="8"/>
                            <Path Stroke="#6C63FF" StrokeThickness="8" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                  Data="M 50,5 A 45,45 0 0 1 95,50"
                                  RenderTransformOrigin="0.5,0.5">
                                <Path.RenderTransform>
                                    <RotateTransform CenterX="50" CenterY="50"/>
                                </Path.RenderTransform>
                                <Path.Triggers>
                                    <EventTrigger RoutedEvent="Path.Loaded">
                                        <BeginStoryboard>
                                            <Storyboard RepeatBehavior="Forever">
                                                <DoubleAnimation Storyboard.TargetProperty="(Path.RenderTransform).(RotateTransform.Angle)"
                                                                 From="0" To="360" Duration="0:0:0.8"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Path.Triggers>
                            </Path>
                        </Canvas>
                    </Viewbox>
                    <TextBlock Text="Loading data..." FontSize="15"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               HorizontalAlignment="Center" Margin="0,14,0,0"/>
                </StackPanel>
            </Grid>
        </Grid>

        <!-- ===== NOTIFICATION OVERLAY ===== -->
        <ItemsControl Grid.RowSpan="2"
                      HorizontalAlignment="Right"
                      VerticalAlignment="Top"
                      Margin="0,60,16,0"
                      Panel.ZIndex="999"
                      IsHitTestVisible="True"
                      ItemsSource="{Binding Source={x:Static svc:NotificationService.Instance},
                                            Path=Notifications}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <ctrl:NotificationControl Margin="0,0,0,8"/>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
        </ItemsControl>
        </Grid>
    </Border>
</Window>
