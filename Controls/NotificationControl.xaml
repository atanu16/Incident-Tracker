<UserControl x:Class="IncidentTracker.Controls.NotificationControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:IncidentTracker.Converters"
             Width="320">

    <UserControl.Resources>
        <conv:NotificationTypeToBrushConverter x:Key="TypeToBrush"/>
    </UserControl.Resources>

    <UserControl.Triggers>
        <EventTrigger RoutedEvent="Loaded">
            <BeginStoryboard x:Name="SlideInStoryboard">
                <Storyboard>
                    <DoubleAnimation Storyboard.TargetName="RootBorder"
                                     Storyboard.TargetProperty="Opacity"
                                     From="0" To="1" Duration="0:0:0.3"/>
                    <DoubleAnimation Storyboard.TargetName="SlideTransform"
                                     Storyboard.TargetProperty="X"
                                     From="60" To="0" Duration="0:0:0.35">
                        <DoubleAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                </Storyboard>
            </BeginStoryboard>
        </EventTrigger>
    </UserControl.Triggers>

    <Border x:Name="RootBorder"
            CornerRadius="12"
            Padding="14,12"
            Opacity="0"
            Background="{DynamicResource CardBgBrush}"
            BorderBrush="{Binding Type, Converter={StaticResource TypeToBrush}}"
            BorderThickness="0,0,0,3">
        <Border.RenderTransform>
            <TranslateTransform x:Name="SlideTransform" X="60"/>
        </Border.RenderTransform>
        <Border.Effect>
            <DropShadowEffect ShadowDepth="3" BlurRadius="16" Opacity="0.45" Direction="270" Color="#000000"/>
        </Border.Effect>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Icon Circle -->
            <Border Grid.Column="0"
                    Width="38" Height="38"
                    CornerRadius="19"
                    Background="{Binding Type, Converter={StaticResource TypeToBrush}}"
                    VerticalAlignment="Center"
                    Margin="0,0,12,0">
                <TextBlock Text="{Binding Icon}"
                           Foreground="White"
                           FontSize="16"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
            </Border>

            <!-- Text Content -->
            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                <TextBlock Text="{Binding Title}"
                           FontWeight="SemiBold"
                           FontSize="13"
                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                <TextBlock Text="{Binding Message}"
                           FontSize="11"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           TextWrapping="Wrap"
                           Margin="0,3,0,0"/>
            </StackPanel>

            <!-- Close Button -->
            <Button Grid.Column="2"
                    x:Name="CloseBtn"
                    Content="✕"
                    FontSize="11"
                    Background="Transparent"
                    Foreground="{DynamicResource TextMutedBrush}"
                    BorderThickness="0"
                    Cursor="Hand"
                    VerticalAlignment="Top"
                    Padding="4"
                    Click="CloseBtn_Click"/>
        </Grid>
    </Border>
</UserControl>
