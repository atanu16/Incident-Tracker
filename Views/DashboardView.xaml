<UserControl x:Class="IncidentTracker.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:IncidentTracker.Converters">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:InverseBoolToVisibilityConverter x:Key="InvBoolToVis"/>
        <conv:StatusToColorConverter x:Key="StatusToColor"/>
        <conv:CountToVisibilityConverter x:Key="CountToVis"/>
    </UserControl.Resources>

    <Grid Background="{DynamicResource WindowBgBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar Row -->
        <Border Grid.Row="0" Background="{DynamicResource CardBgBrush}"
                BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="0,0,0,1"
                Padding="20,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Search Box -->
                <Grid Grid.Column="0" Margin="0,0,12,0">
                    <TextBox x:Name="SearchBox"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             Background="{DynamicResource InputBgBrush}"
                             Foreground="{DynamicResource TextPrimaryBrush}"
                             BorderBrush="{DynamicResource InputBorderBrush}"
                             BorderThickness="1" Padding="38,10,10,10"
                             FontSize="13" CaretBrush="{DynamicResource TextPrimaryBrush}">
                        <TextBox.Template>
                            <ControlTemplate TargetType="TextBox">
                                <Border Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="8">
                                    <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"
                                                  VerticalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsFocused" Value="True">
                                        <Setter Property="BorderBrush" Value="{DynamicResource InputFocusBorderBrush}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </TextBox.Template>
                    </TextBox>
                    <TextBlock Text="🔍  Search by Subject, Incident, Description..."
                               Foreground="{DynamicResource TextMutedBrush}" FontSize="12"
                               IsHitTestVisible="False" VerticalAlignment="Center" Margin="14,0,0,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Text, ElementName=SearchBox}" Value="">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>

                <!-- Refresh Button -->
                <Button Grid.Column="1" Command="{Binding RefreshCommand}"
                        Background="{DynamicResource SecondaryBtnBrush}"
                        Foreground="{DynamicResource TextPrimaryBrush}"
                        BorderThickness="1" BorderBrush="{DynamicResource CardBorderBrush}"
                        Padding="16,10" Margin="0,0,10,0" Cursor="Hand" FontSize="13">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="8" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SecondaryBtnHoverBrush}"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bd" Property="Opacity" Value="0.75"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                    <StackPanel Orientation="Horizontal" Margin="2,0">
                        <TextBlock Text="↺" FontSize="16" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Refresh" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- Add New Button -->
                <Button Grid.Column="2" Command="{Binding AddNewCommand}"
                        Background="{DynamicResource AccentBrush}"
                        Foreground="White" BorderThickness="0"
                        Padding="16,10" Cursor="Hand" FontSize="13">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                    CornerRadius="8" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AccentHoverBrush}"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AccentPressedBrush}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                    <StackPanel Orientation="Horizontal" Margin="2,0">
                        <TextBlock Text="＋" FontSize="15" FontWeight="Bold" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Add New" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- Stats Row -->
        <Border Grid.Row="1" Background="{DynamicResource PanelBgBrush}"
                BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="0,0,0,1"
                Padding="20,10">
            <StackPanel Orientation="Horizontal">
                <Border Background="{DynamicResource BadgeInProgressBgBrush}" CornerRadius="20" Padding="12,4">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⚡ " Foreground="White" FontSize="12"/>
                        <TextBlock Foreground="White" FontSize="12" FontWeight="SemiBold">
                            <Run Text="{Binding TotalInProgress, Mode=OneWay}"/>
                            <Run Text=" In Progress"/>
                        </TextBlock>
                    </StackPanel>
                </Border>
                <TextBlock Foreground="{DynamicResource TextMutedBrush}" FontSize="12"
                           Margin="12,0,0,0" VerticalAlignment="Center">
                    <Run Text="{Binding DisplayedRecords.Count, Mode=OneWay}"/>
                    <Run Text=" shown"/>
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- Data Grid -->
        <Border Grid.Row="2" Margin="16" CornerRadius="12"
                Background="{DynamicResource CardBgBrush}"
                BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
            <Grid x:Name="DgContainer">
                <Grid.OpacityMask>
                    <VisualBrush>
                        <VisualBrush.Visual>
                            <Border Background="Black" CornerRadius="11"
                                    Width="{Binding ActualWidth, ElementName=DgContainer}"
                                    Height="{Binding ActualHeight, ElementName=DgContainer}"/>
                        </VisualBrush.Visual>
                    </VisualBrush>
                </Grid.OpacityMask>
                <!-- Empty State -->
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                            Visibility="{Binding DisplayedRecords.Count, Converter={StaticResource CountToVis}}">
                    <TextBlock Text="📋" FontSize="48" HorizontalAlignment="Center" Opacity="0.3"/>
                    <TextBlock Text="No in-progress incidents" FontSize="16"
                               Foreground="{DynamicResource TextMutedBrush}"
                               HorizontalAlignment="Center" Margin="0,12,0,4"/>
                    <TextBlock Text="All incidents are completed or no data found."
                               FontSize="12" Foreground="{DynamicResource TextMutedBrush}"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <DataGrid ItemsSource="{Binding DisplayedRecords}"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          GridLinesVisibility="Horizontal"
                          HeadersVisibility="Column"
                          SelectionMode="Single"
                          CanUserReorderColumns="False"
                          CanUserResizeRows="False"
                          RowHeight="42"
                          FontSize="12"
                          Background="Transparent"
                          Foreground="{DynamicResource TextPrimaryBrush}"
                          BorderThickness="0"
                          HorizontalGridLinesBrush="{DynamicResource DgBorderBrush}"
                          AlternatingRowBackground="{DynamicResource DgRowAltBgBrush}"
                          RowBackground="{DynamicResource DgRowBgBrush}"
                          SelectionUnit="FullRow">
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="{DynamicResource DgHeaderBgBrush}"/>
                            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="FontSize" Value="11"/>
                            <Setter Property="Padding" Value="14,10"/>
                            <Setter Property="BorderBrush" Value="{DynamicResource DgBorderBrush}"/>
                            <Setter Property="BorderThickness" Value="0,0,1,1"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.CellStyle>
                        <Style TargetType="DataGridCell">
                            <Setter Property="Padding" Value="14,0"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="DataGridCell">
                                        <Border Background="{TemplateBinding Background}"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource DgSelectionBgBrush}"/>
                                    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.CellStyle>
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource DgRowHoverBgBrush}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="DATE" Width="145"
                                            Binding="{Binding Date, StringFormat=yyyy-MM-dd}"/>
                        <DataGridTextColumn Header="CREATED BY" Width="150"
                                            Binding="{Binding CreatedBy}"/>
                        <DataGridTextColumn Header="SUBJECT LINE" Width="200"
                                            Binding="{Binding SubjectLine}"/>
                        <DataGridTextColumn Header="INCIDENT" Width="140"
                                            Binding="{Binding Incident}"/>
                        <DataGridTemplateColumn Header="STATUS" Width="120">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border CornerRadius="12" Padding="10,3" HorizontalAlignment="Left" VerticalAlignment="Center"
                                            Background="{Binding Status, Converter={StaticResource StatusToColor}}">
                                        <TextBlock Text="{Binding Status}" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="DESCRIPTION" Width="*"
                                            Binding="{Binding ShortDescription}"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <!-- Status Bar -->
        <Border Grid.Row="3" Background="{DynamicResource PanelBgBrush}"
                BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="0,1,0,0"
                Padding="20,8">
            <TextBlock FontSize="11" Foreground="{DynamicResource TextMutedBrush}">
                <Run Text="Showing in-progress incidents only • Click"/>
                <Run Text=" All Records" FontWeight="SemiBold" Foreground="{DynamicResource AccentBrush}"/>
                <Run Text=" tab to see all data"/>
            </TextBlock>
        </Border>
    </Grid>
</UserControl>
