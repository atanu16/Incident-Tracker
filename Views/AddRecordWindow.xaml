<Window x:Class="IncidentTracker.Views.AddRecordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:IncidentTracker.Converters"
        Title="Add New Incident"
        Width="520" Height="600"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource WindowBgBrush}"
        FontFamily="Segoe UI">

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:InverseBoolConverter x:Key="InvBool"/>

        <Style x:Key="FormLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <Style x:Key="FormTextBox" TargetType="TextBox">
            <Setter Property="Background" Value="{DynamicResource InputBgBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource InputBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="CaretBrush" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="{DynamicResource InputFocusBorderBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <!-- Header -->
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{DynamicResource CardBgBrush}"
                BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="0,0,0,1"
                Padding="24,18">
            <StackPanel>
                <TextBlock Text="📝  Add New Incident Record"
                           FontSize="18" FontWeight="SemiBold"
                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                <TextBlock Text="Fill in the details below and click Submit to add the record."
                           FontSize="12" Foreground="{DynamicResource TextMutedBrush}"
                           Margin="0,4,0,0"/>
            </StackPanel>
        </Border>

        <!-- Form Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24,20" IsEnabled="{Binding IsLoading, Converter={StaticResource InvBool}}">

                <!-- Date Field -->
                <TextBlock Text="DATE &amp; TIME" Style="{StaticResource FormLabel}"/>
                <DatePicker SelectedDate="{Binding Date, Mode=TwoWay}"
                            Background="{DynamicResource InputBgBrush}"
                            Foreground="{DynamicResource TextPrimaryBrush}"
                            BorderBrush="{DynamicResource InputBorderBrush}"
                            BorderThickness="1"
                            FontSize="13"
                            Padding="12,8"
                            Margin="0,0,0,16"
                            Height="40">
                    <DatePicker.CalendarStyle>
                        <Style TargetType="Calendar">
                            <Setter Property="Background" Value="{DynamicResource CardBgBrush}"/>
                            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                        </Style>
                    </DatePicker.CalendarStyle>
                </DatePicker>

                <!-- Created By Field -->
                <TextBlock Text="CREATED BY" Style="{StaticResource FormLabel}"/>
                <TextBox Text="{Binding CreatedBy, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource FormTextBox}"
                         Margin="0,0,0,16"/>

                <!-- Subject Line Field -->
                <TextBlock Text="SUBJECT LINE *" Style="{StaticResource FormLabel}"/>
                <Grid Margin="0,0,0,16">
                    <TextBox x:Name="SubjectBox"
                             Text="{Binding SubjectLine, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource FormTextBox}"/>
                    <TextBlock Text="Required — brief title for this incident"
                               Foreground="{DynamicResource TextMutedBrush}" FontSize="12"
                               IsHitTestVisible="False" VerticalAlignment="Center" Margin="14,0,0,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Text, ElementName=SubjectBox}" Value="">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>

                <!-- Incident Field -->
                <TextBlock Text="INCIDENT ID / REFERENCE" Style="{StaticResource FormLabel}"/>
                <Grid Margin="0,0,0,16">
                    <TextBox x:Name="IncidentBox"
                             Text="{Binding Incident, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource FormTextBox}"/>
                    <TextBlock Text="e.g. INC-001, TKT-5432"
                               Foreground="{DynamicResource TextMutedBrush}" FontSize="12"
                               IsHitTestVisible="False" VerticalAlignment="Center" Margin="14,0,0,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Text, ElementName=IncidentBox}" Value="">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>

                <!-- Status Field -->
                <TextBlock Text="STATUS" Style="{StaticResource FormLabel}"/>
                <ComboBox SelectedItem="{Binding Status}"
                          ItemsSource="{Binding StatusOptions}"
                          Background="{DynamicResource InputBgBrush}"
                          Foreground="{DynamicResource TextPrimaryBrush}"
                          BorderBrush="{DynamicResource InputBorderBrush}"
                          BorderThickness="1"
                          FontSize="13"
                          Padding="8,10"
                          Height="42"
                          Margin="0,0,0,16">
                    <ComboBox.Template>
                        <ControlTemplate TargetType="ComboBox">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="8" Padding="{TemplateBinding Padding}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <ContentPresenter Grid.Column="0"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                      VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="▾" VerticalAlignment="Center"
                                               Foreground="{DynamicResource TextSecondaryBrush}"
                                               Margin="8,0,0,0"/>
                                    <Popup x:Name="PART_Popup" IsOpen="{TemplateBinding IsDropDownOpen}"
                                           AllowsTransparency="True" Focusable="False"
                                           PopupAnimation="Slide" Placement="Bottom">
                                        <Border Background="{DynamicResource CardBgBrush}"
                                                BorderBrush="{DynamicResource CardBorderBrush}"
                                                BorderThickness="1" CornerRadius="8" Padding="4">
                                            <Border.Effect>
                                                <DropShadowEffect ShadowDepth="4" BlurRadius="12" Opacity="0.4"/>
                                            </Border.Effect>
                                            <ScrollViewer>
                                                <ItemsPresenter/>
                                            </ScrollViewer>
                                        </Border>
                                    </Popup>
                                    <ToggleButton Grid.ColumnSpan="2"
                                                  IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                                  Background="Transparent" BorderThickness="0" Opacity="0"/>
                                </Grid>
                            </Border>
                        </ControlTemplate>
                    </ComboBox.Template>
                    <ComboBox.ItemContainerStyle>
                        <Style TargetType="ComboBoxItem">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                            <Setter Property="Padding" Value="12,8"/>
                            <Setter Property="FontSize" Value="13"/>
                            <Style.Triggers>
                                <Trigger Property="IsHighlighted" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource DgSelectionBgBrush}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </ComboBox.ItemContainerStyle>
                </ComboBox>

                <!-- Short Description -->
                <TextBlock Text="SHORT DESCRIPTION" Style="{StaticResource FormLabel}"/>
                <Grid Margin="0,0,0,8">
                    <TextBox x:Name="DescBox"
                             Text="{Binding ShortDescription, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource FormTextBox}"
                             Height="90" AcceptsReturn="True"
                             TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                             VerticalContentAlignment="Top"/>
                    <TextBlock Text="Describe the incident in a few sentences..."
                               Foreground="{DynamicResource TextMutedBrush}" FontSize="12"
                               IsHitTestVisible="False" VerticalAlignment="Top"
                               Margin="14,12,0,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Text, ElementName=DescBox}" Value="">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
            </StackPanel>
        </ScrollViewer>

        <!-- Footer Buttons -->
        <Border Grid.Row="2" Background="{DynamicResource CardBgBrush}"
                BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="0,1,0,0"
                Padding="24,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Loading indicator -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center"
                            Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
                    <Viewbox Width="18" Height="18">
                        <Canvas Width="100" Height="100">
                            <Ellipse Width="90" Height="90" Canvas.Left="5" Canvas.Top="5"
                                     Stroke="#2A2A4A" StrokeThickness="8"/>
                            <Path Stroke="#6C63FF" StrokeThickness="8"
                                  Data="M 50,5 A 45,45 0 0 1 95,50"
                                  RenderTransformOrigin="0.5,0.5">
                                <Path.RenderTransform>
                                    <RotateTransform CenterX="50" CenterY="50"/>
                                </Path.RenderTransform>
                                <Path.Triggers>
                                    <EventTrigger RoutedEvent="Path.Loaded">
                                        <BeginStoryboard>
                                            <Storyboard RepeatBehavior="Forever">
                                                <DoubleAnimation Storyboard.TargetProperty="(Path.RenderTransform).(RotateTransform.Angle)"
                                                                 From="0" To="360" Duration="0:0:0.9"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </EventTrigger>
                                </Path.Triggers>
                            </Path>
                        </Canvas>
                    </Viewbox>
                    <TextBlock Text="  Saving..." Foreground="{DynamicResource TextSecondaryBrush}"
                               FontSize="13" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Cancel Button -->
                <Button Grid.Column="1" Command="{Binding CancelCommand}"
                        Background="{DynamicResource SecondaryBtnBrush}"
                        Foreground="{DynamicResource TextPrimaryBrush}"
                        BorderThickness="1" BorderBrush="{DynamicResource CardBorderBrush}"
                        Padding="20,11" Margin="0,0,10,0" Cursor="Hand" FontSize="13"
                        IsEnabled="{Binding IsLoading, Converter={StaticResource InvBool}}">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="8" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SecondaryBtnHoverBrush}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                    <TextBlock Text="Cancel"/>
                </Button>

                <!-- Submit Button -->
                <Button Grid.Column="2" Command="{Binding SubmitCommand}"
                        Background="{DynamicResource AccentBrush}"
                        Foreground="White" BorderThickness="0"
                        Padding="20,11" Cursor="Hand" FontSize="13"
                        IsEnabled="{Binding IsLoading, Converter={StaticResource InvBool}}">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                    CornerRadius="8" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AccentHoverBrush}"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="Bd" Property="Opacity" Value="0.5"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="✓ " FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
                        <TextBlock Text="Submit Record" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>
    </Grid>
</Window>
