<UserControl x:Class="IncidentTracker.Views.EditView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:IncidentTracker.Converters">

    <UserControl.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:CountToVisibilityConverter x:Key="CountToVis"/>
    </UserControl.Resources>

    <Grid Background="{DynamicResource WindowBgBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Toolbar Row -->
        <Border Grid.Row="0" Background="{DynamicResource CardBgBrush}"
                BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="0,0,0,1"
                Padding="20,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="Edit Records" FontSize="16" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <TextBlock Text="Click any cell to edit. Use Tab to move between fields."
                               FontSize="11" Foreground="{DynamicResource TextMutedBrush}" Margin="0,2,0,0"/>
                </StackPanel>

                <!-- Refresh Button -->
                <Button Grid.Column="1" Command="{Binding RefreshCommand}"
                        Background="{DynamicResource SecondaryBtnBrush}"
                        Foreground="{DynamicResource TextPrimaryBrush}"
                        BorderThickness="1" BorderBrush="{DynamicResource CardBorderBrush}"
                        Padding="16,10" Margin="0,0,10,0" Cursor="Hand" FontSize="13">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="8" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SecondaryBtnHoverBrush}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="↺ " FontSize="15" VerticalAlignment="Center"/>
                        <TextBlock Text="Discard &amp; Reload" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <!-- Save Button -->
                <Button Grid.Column="2" Command="{Binding SaveCommand}"
                        Background="{DynamicResource SuccessBrush}"
                        Foreground="White" BorderThickness="0"
                        Padding="16,10" Cursor="Hand" FontSize="13">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                    CornerRadius="8" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Opacity" Value="0.85"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bd" Property="Opacity" Value="0.7"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="💾 " FontSize="14" VerticalAlignment="Center"/>
                        <TextBlock Text="Save All Changes" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>

        <!-- Info Banner -->
        <Border Grid.Row="1" Background="#1A6C63FF"
                BorderBrush="{DynamicResource AccentBrush}" BorderThickness="0,0,0,1"
                Padding="20,10">
            <TextBlock Foreground="{DynamicResource AccentBrush}" FontSize="12">
                <Run Text="ℹ  "/>
                <Run Text="Changes are saved in-memory until you click 'Save All Changes'. All rows in the Excel file will be updated."/>
            </TextBlock>
        </Border>

        <!-- Editable Data Grid -->
        <Border Grid.Row="2" Margin="16" CornerRadius="12"
                Background="{DynamicResource CardBgBrush}"
                BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
            <Grid>
                <!-- Empty State -->
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                            Visibility="{Binding Records.Count, Converter={StaticResource CountToVis}}">
                    <TextBlock Text="✏" FontSize="48" HorizontalAlignment="Center" Opacity="0.3"/>
                    <TextBlock Text="No records to edit" FontSize="16"
                               Foreground="{DynamicResource TextMutedBrush}"
                               HorizontalAlignment="Center" Margin="0,12,0,0"/>
                </StackPanel>

                <DataGrid x:Name="EditGrid"
                          ItemsSource="{Binding Records}"
                          AutoGenerateColumns="False"
                          IsReadOnly="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          GridLinesVisibility="Horizontal"
                          HeadersVisibility="Column"
                          SelectionMode="Single"
                          CanUserReorderColumns="False"
                          CanUserResizeRows="False"
                          RowHeight="44"
                          FontSize="12"
                          Background="Transparent"
                          Foreground="{DynamicResource TextPrimaryBrush}"
                          BorderThickness="0"
                          HorizontalGridLinesBrush="{DynamicResource DgBorderBrush}"
                          AlternatingRowBackground="{DynamicResource DgRowAltBgBrush}"
                          RowBackground="{DynamicResource DgRowBgBrush}"
                          SelectionUnit="FullRow">
                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="{DynamicResource DgHeaderBgBrush}"/>
                            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="FontSize" Value="11"/>
                            <Setter Property="Padding" Value="14,10"/>
                            <Setter Property="BorderBrush" Value="{DynamicResource DgBorderBrush}"/>
                            <Setter Property="BorderThickness" Value="0,0,1,1"/>
                        </Style>
                    </DataGrid.ColumnHeaderStyle>
                    <DataGrid.CellStyle>
                        <Style TargetType="DataGridCell">
                            <Setter Property="Padding" Value="10,0"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="DataGridCell">
                                        <Border Background="{TemplateBinding Background}"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource DgSelectionBgBrush}"/>
                                    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                </Trigger>
                                <Trigger Property="IsEditing" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource InputBgBrush}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.CellStyle>
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{DynamicResource DgRowHoverBgBrush}"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>

                    <DataGrid.Columns>
                        <!-- Date Column -->
                        <DataGridTemplateColumn Header="DATE" Width="160" SortMemberPath="Date">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Date, StringFormat=yyyy-MM-dd HH:mm}"
                                               VerticalAlignment="Center" Margin="4,0"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                            <DataGridTemplateColumn.CellEditingTemplate>
                                <DataTemplate>
                                    <DatePicker SelectedDate="{Binding Date, UpdateSourceTrigger=PropertyChanged}"
                                                Background="{DynamicResource InputBgBrush}"
                                                Foreground="{DynamicResource TextPrimaryBrush}"
                                                BorderBrush="{DynamicResource InputBorderBrush}"
                                                FontSize="12" Padding="4,2"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellEditingTemplate>
                        </DataGridTemplateColumn>

                        <!-- Created By -->
                        <DataGridTextColumn Header="CREATED BY" Width="140"
                                            Binding="{Binding CreatedBy, UpdateSourceTrigger=PropertyChanged}">
                            <DataGridTextColumn.EditingElementStyle>
                                <Style TargetType="TextBox">
                                    <Setter Property="Background" Value="{DynamicResource InputBgBrush}"/>
                                    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                    <Setter Property="BorderBrush" Value="{DynamicResource InputFocusBorderBrush}"/>
                                    <Setter Property="Padding" Value="4,2"/>
                                </Style>
                            </DataGridTextColumn.EditingElementStyle>
                        </DataGridTextColumn>

                        <!-- Subject Line -->
                        <DataGridTextColumn Header="SUBJECT LINE" Width="190"
                                            Binding="{Binding SubjectLine, UpdateSourceTrigger=PropertyChanged}">
                            <DataGridTextColumn.EditingElementStyle>
                                <Style TargetType="TextBox">
                                    <Setter Property="Background" Value="{DynamicResource InputBgBrush}"/>
                                    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                    <Setter Property="BorderBrush" Value="{DynamicResource InputFocusBorderBrush}"/>
                                    <Setter Property="Padding" Value="4,2"/>
                                </Style>
                            </DataGridTextColumn.EditingElementStyle>
                        </DataGridTextColumn>

                        <!-- Incident -->
                        <DataGridTextColumn Header="INCIDENT" Width="130"
                                            Binding="{Binding Incident, UpdateSourceTrigger=PropertyChanged}">
                            <DataGridTextColumn.EditingElementStyle>
                                <Style TargetType="TextBox">
                                    <Setter Property="Background" Value="{DynamicResource InputBgBrush}"/>
                                    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                    <Setter Property="BorderBrush" Value="{DynamicResource InputFocusBorderBrush}"/>
                                    <Setter Property="Padding" Value="4,2"/>
                                </Style>
                            </DataGridTextColumn.EditingElementStyle>
                        </DataGridTextColumn>

                        <!-- Status (Dropdown) -->
                        <DataGridTemplateColumn Header="STATUS" Width="140" SortMemberPath="Status">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Status}" VerticalAlignment="Center" Margin="4,0"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                            <DataGridTemplateColumn.CellEditingTemplate>
                                <DataTemplate>
                                    <ComboBox SelectedItem="{Binding Status, UpdateSourceTrigger=PropertyChanged}"
                                              ItemsSource="{Binding DataContext.StatusOptions,
                                                RelativeSource={RelativeSource AncestorType=UserControl}}"
                                              Background="{DynamicResource InputBgBrush}"
                                              Foreground="{DynamicResource TextPrimaryBrush}"
                                              BorderBrush="{DynamicResource InputFocusBorderBrush}"
                                              FontSize="12" Padding="4,2"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellEditingTemplate>
                        </DataGridTemplateColumn>

                        <!-- Short Description -->
                        <DataGridTextColumn Header="DESCRIPTION" Width="*"
                                            Binding="{Binding ShortDescription, UpdateSourceTrigger=PropertyChanged}">
                            <DataGridTextColumn.EditingElementStyle>
                                <Style TargetType="TextBox">
                                    <Setter Property="Background" Value="{DynamicResource InputBgBrush}"/>
                                    <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                                    <Setter Property="BorderBrush" Value="{DynamicResource InputFocusBorderBrush}"/>
                                    <Setter Property="Padding" Value="4,2"/>
                                </Style>
                            </DataGridTextColumn.EditingElementStyle>
                        </DataGridTextColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Loading Spinner -->
                <Grid Background="{DynamicResource OverlayBgBrush}"
                      Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <Viewbox Width="48" Height="48">
                            <Canvas Width="100" Height="100">
                                <Ellipse Width="90" Height="90" Canvas.Left="5" Canvas.Top="5"
                                         Stroke="#2A2A4A" StrokeThickness="8"/>
                                <Path Stroke="#00C875" StrokeThickness="8" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                      Data="M 50,5 A 45,45 0 0 1 95,50"
                                      RenderTransformOrigin="0.5,0.5">
                                    <Path.RenderTransform>
                                        <RotateTransform CenterX="50" CenterY="50"/>
                                    </Path.RenderTransform>
                                    <Path.Triggers>
                                        <EventTrigger RoutedEvent="Path.Loaded">
                                            <BeginStoryboard>
                                                <Storyboard RepeatBehavior="Forever">
                                                    <DoubleAnimation Storyboard.TargetProperty="(Path.RenderTransform).(RotateTransform.Angle)"
                                                                     From="0" To="360" Duration="0:0:0.9"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </Path.Triggers>
                                </Path>
                            </Canvas>
                        </Viewbox>
                        <TextBlock Text="Saving..." Foreground="{DynamicResource TextSecondaryBrush}"
                                   FontSize="13" HorizontalAlignment="Center" Margin="0,10,0,0"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <!-- Status Bar -->
        <Border Grid.Row="3" Background="{DynamicResource PanelBgBrush}"
                BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="0,1,0,0"
                Padding="20,8">
            <TextBlock FontSize="11" Foreground="{DynamicResource TextMutedBrush}">
                <Run Text="{Binding Records.Count, Mode=OneWay}"/>
                <Run Text=" records loaded • Double-click any cell to edit • Press Esc to cancel cell edit"/>
            </TextBlock>
        </Border>
    </Grid>
</UserControl>
